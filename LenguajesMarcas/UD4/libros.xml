<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE catalogo [
  <!ELEMENT catalogo (libro*)>
  <!ELEMENT libro EMPTY>
  <!ATTLIST libro
    titulo CDATA #REQUIRED
    autor CDATA #REQUIRED
    anio CDATA #REQUIRED
    editorial CDATA #REQUIRED
    resumen CDATA #IMPLIED>
]>

<catalogo>
    <libro 
        titulo="Cien años de soledad" 
        autor="Gabriel García Márquez" 
        anio="1967" 
        editorial="Editorial Sudamericana" 
        resumen="La historia de la familia Buendía en el pueblo ficticio de Macondo a lo largo de siete generaciones."
    />

    <libro 
        titulo="El Quijote" 
        autor="Miguel de Cervantes" 
        anio="1605" 
        editorial="Francisco de Robles" 
        resumen="Las aventuras de un hidalgo pobre que enloquece leyendo libros de caballerías y se cree un caballero andante."
    />

    <libro 
        titulo="1984" 
        autor="George Orwell" 
        anio="1949" 
        editorial="Secker &amp; Warburg" 
        resumen="Novela distópica que introduce los conceptos del omnipresente Gran Hermano y la Policía del Pensamiento."
    />
</catalogo>